Options -MultiViews
RewriteEngine On
RewriteBase /

# Forçar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remover .html (opcional, mas boa prática)
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R]

# Se o pedido for uma diretoria sem barra final, adicionar a barra
# Isto é crucial para que o Apache encontre o index.html dentro da diretoria
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*[^/])$ /$1/ [L,R=301]

# Garantir que index.html é servido por defeito
DirectoryIndex index.html

# Página de erro personalizada
ErrorDocument 404 /404.html
